      <mechanicalReduction>0.0144</mechanicalReduction>
    </actuator>
  </transmission>
  <mujoco>
    <compiler meshdir="meshes/" balanceinertia="true" discardvisual="false"/>
    <default>
      <joint armature="3.4707e-08" damping="5.0" frictionloss="0.5"/>
    </default>
    <equality>
      <!-- 四指DIP关节的mimic约束 - 统一使用1.125676 -->
      <!-- polycoef格式: c0 c1 c2 c3 c4 c5，关系: q1 = c0 + c1*q2 + c2*q2^2 + ... -->
      <!-- 对于 mimic: q_dip = 0 + 1.125676*q_mcp + 0*q_mcp^2 + ... -->
      <joint name="couple_index" joint1="index_dip" joint2="index_mcp_pitch" polycoef="0 1.125676 0 0 0 0"/>
      <joint name="couple_middle" joint1="middle_dip" joint2="middle_mcp_pitch" polycoef="0 1.125676 0 0 0 0"/>
      <joint name="couple_ring" joint1="ring_dip" joint2="ring_mcp_pitch" polycoef="0 1.125676 0 0 0 0"/>
      <joint name="couple_pinky" joint1="pinky_dip" joint2="pinky_mcp_pitch" polycoef="0 1.125676 0 0 0 0"/>
      <!-- 大拇指DIP关节的mimic约束 - 使用1.226495 -->
      <joint name="couple_thumb" joint1="thumb_dip" joint2="thumb_cmc_pitch" polycoef="0 1.226495 0 0 0 0"/>
    </equality>
  </mujoco>
  <gazebo reference="hand_base_link">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <selfCollide>true</selfCollide>
  </gazebo>
  <gazebo reference="thumb_distal">
